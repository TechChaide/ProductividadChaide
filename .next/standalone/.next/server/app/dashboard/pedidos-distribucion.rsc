              (function(){
                function attach(){
                  try {
                    if (typeof window !== 'undefined') {
                      if (!window.Zebra && window.BrowserPrint) {
                        window.Zebra = { BrowserPrint: window.BrowserPrint };
                        console.log('[BrowserPrint] Wrapper Zebra creado');
